# Core
APP_URL=http://localhost:3000
NODE_ENV=development
DATABASE_URL=postgres://user:password@localhost:5432/6esk
SESSION_SECRET=replace-with-long-random-string
SESSION_COOKIE_NAME=sixesk_session
SESSION_TTL_DAYS=14
AUTH_PROVIDER=password
AUTH_OAUTH_ENABLED=false
AUTH_REQUIRE_MFA_ADMIN=true
AUTH_MFA_SECRET_ENCRYPTION_KEY=replace-with-32-byte-or-long-random-secret
AUTH_SESSION_DEVICE_TRACKING=true
AUTH_BETTER_AUTH_ROUTE_ENABLED=false
AUTH_BETTER_AUTH_DB_BRIDGE_READY=false
AUTH_ALLOWED_EMAIL_DOMAINS=example.com

# Open-source auth foundation
# Better Auth is the embedded app auth layer; Keycloak-compatible OIDC can be used later as a broker.
BETTER_AUTH_SECRET=replace-with-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_TENANT_ID=organizations
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=

# Auth cache provider: none, upstash, valkey, or redis.
# Production OAuth should use upstash, valkey, or redis.
AUTH_CACHE_PROVIDER=none
AUTH_REDIS_URL=redis://localhost:6379

# Email (Resend)
RESEND_API_KEY=replace-with-resend-key
RESEND_WEBHOOK_SECRET=replace-with-resend-webhook-secret
RESEND_FROM_DOMAIN=example.com
SUPPORT_ADDRESS=support@example.com
# Shared-secret fallback for maintenance workers and trusted external ingress.
INBOUND_SHARED_SECRET=replace-with-inbound-shared-secret
# Require explicit tenant scope on shared-secret ingress and provider-owned webhook routing.
# Defaults to true when NODE_ENV=production; keep true for external-tenant launch.
TENANT_INGRESS_REQUIRE_SCOPE=true
# Tenant envelope identity used by maintenance scripts and service-to-service workers.
TENANT_INGRESS_TENANT=primary
TENANT_INGRESS_WORKSPACE=primary
# Require HMAC-signed tenant envelopes on shared-secret machine ingress.
# Signature payload: tenant-ingress.v1, tenant, workspace, method, path/query, timestamp.
# Defaults to true when NODE_ENV=production; keep true for external-tenant launch.
TENANT_INGRESS_REQUIRE_SIGNATURE=true
TENANT_INGRESS_SIGNATURE_MAX_SKEW_SECONDS=300
TENANT_INGRESS_SIGNING_SECRETS_JSON={"tenant-a:workspace-a":"replace-with-tenant-ingress-signing-secret"}
TENANT_INGRESS_SECRET_ENCRYPTION_KEY=replace-with-32-byte-or-long-random-secret
# Temporary compatibility fallback only. Keep false in production.
TENANT_INGRESS_ALLOW_GLOBAL_SIGNING_SECRET=false
# Require public portal/webchat origins to map to a tenant workspace.
# Defaults to true when NODE_ENV=production; keep true for external-tenant launch.
TENANT_PUBLIC_INGRESS_REQUIRE_ORIGIN=true
TENANT_PUBLIC_INGRESS_ORIGINS_JSON={"https://support.example.com":{"tenantKey":"tenant-a","workspaceKey":"workspace-a"}}
# Require provider webhook signatures to use tenant/workspace-scoped secrets.
# Defaults to true when NODE_ENV=production; keep true for external-tenant launch.
TENANT_PROVIDER_WEBHOOK_REQUIRE_SECRETS=true
TENANT_QUERY_GUARD_MODE=strict
# Production billing safety: entitlement reads and billable usage metering must fail closed.
ENTITLEMENTS_FAIL_CLOSED=true
MODULE_METERING_FAIL_CLOSED=true
BILLING_VAT_RATE_PERCENT=15
PROVIDER_WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-32-byte-or-long-random-secret
TENANT_PROVIDER_WEBHOOK_SECRETS_JSON={"tenant-a:workspace-a:whatsapp:app_secret":"replace-with-meta-app-secret","tenant-a:workspace-a:resend:webhook_secret":"replace-with-resend-webhook-secret","tenant-a:workspace-a:twilio:auth_token:ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx":"replace-with-twilio-auth-token","tenant-a:workspace-a:managed_stt:http_secret":"replace-with-managed-stt-http-secret","tenant-a:workspace-a:deepgram:callback_token":"replace-with-deepgram-callback-token"}
AGENT_SECRET_KEY=replace-with-agent-secret-key
AGENT_ORG_ID=default-support
ADMIN_IP_ALLOWLIST=127.0.0.1,::1
AGENT_IP_ALLOWLIST=
INBOUND_ALERT_WEBHOOK=
SECURITY_ALERT_WEBHOOK=https://alerts.example.com/security
INBOUND_ALERT_THRESHOLD=5
INBOUND_ALERT_WINDOW_MINUTES=30
INBOUND_ALERT_COOLDOWN_MINUTES=60
INBOUND_RETRY_LIMIT=25
INBOUND_JOB_INTERVAL_SECONDS=0
INBOUND_JOB_MAX_RUNS=1
INBOUND_ALERT_EVERY_RUN=true
AGENT_MERGE_MIN_CONFIDENCE=0.85
TICKET_MERGE_MAX_MOVE_ROWS=5000
WHATSAPP_VERIFY_TOKEN=replace-with-whatsapp-verify-token
WHATSAPP_APP_SECRET=replace-with-whatsapp-app-secret
WHATSAPP_OUTBOX_SECRET=replace-with-whatsapp-outbox-secret
WHATSAPP_GRAPH_VERSION=v19.0
CALLS_PROVIDER=mock
CALLS_PROVIDER_HTTP_URL=
CALLS_PROVIDER_HTTP_SECRET=
CALLS_PROVIDER_HTTP_TIMEOUT_MS=8000
CALLS_TWILIO_ACCOUNT_SID=
CALLS_TWILIO_AUTH_TOKEN=
CALLS_TWILIO_API_KEY_SID=
CALLS_TWILIO_API_KEY_SECRET=
# Optional for future browser-originated outbound calls. Incoming desk calls work without it.
CALLS_TWILIO_TWIML_APP_SID=
CALLS_TWILIO_FROM_NUMBER=
# Legacy migration fallback only. Normal v1 desk flow should ring browser clients inside 6esk.
CALLS_TWILIO_BRIDGE_TARGET=
CALLS_TWILIO_OPERATOR_RING_TIMEOUT_SECONDS=25
CALLS_TWILIO_CLIENT_TOKEN_TTL_SECONDS=3600
CALLS_OPERATOR_PRESENCE_TTL_SECONDS=90
CALLS_TWILIO_QUEUE_RETRY_LIMIT=6
# Optional comma-separated allowlist of caller IDs the app may request per call
CALLS_TWILIO_ALLOWED_CALLER_IDS=
CALLS_WEBHOOK_SECRET=replace-with-calls-webhook-secret
# Recommended secure signing string: "${timestamp}.${rawBody}".
CALLS_WEBHOOK_MAX_SKEW_SECONDS=300
# Temporary migration-only fallback. Keep false in production.
CALLS_WEBHOOK_ALLOW_LEGACY_BODY_SIGNATURE=false
CALLS_OUTBOX_SECRET=replace-with-calls-outbox-secret
CALLS_OUTBOX_PROCESSING_RECOVERY_SECONDS=300
CALLS_PROVIDER_FROM_PHONE=
CALLS_ENABLED=true
CALLS_REQUIRE_CONSENT=false
CALLS_CONSENT_TERMS_VERSION=
CALLS_ALLOWED_HOURS_TIMEZONE=UTC
CALLS_ALLOWED_HOURS_DAYS=
CALLS_ALLOWED_HOURS_START=
CALLS_ALLOWED_HOURS_END=
CALLS_MAX_CALLS_PER_HOUR=
CALLS_AI_MAX_CALLS_PER_HOUR=

# Speech-to-text / transcript processing
CALLS_STT_PROVIDER=managed_http
CALLS_STT_PROVIDER_HTTP_URL=http://localhost:3000/api/internal/calls/stt/deepgram
CALLS_STT_PROVIDER_HTTP_SECRET=replace-with-managed-stt-http-secret
CALLS_STT_PROVIDER_HTTP_TIMEOUT_MS=15000
CALLS_STT_DEEPGRAM_API_URL=https://api.deepgram.com/v1/listen
CALLS_STT_DEEPGRAM_API_KEY=replace-with-deepgram-api-key
CALLS_STT_DEEPGRAM_CALLBACK_TOKEN=replace-with-deepgram-callback-token
CALLS_STT_DEEPGRAM_MODEL=nova-3
CALLS_STT_DEEPGRAM_LANGUAGE=
CALLS_TRANSCRIPT_SHARED_SECRET=replace-with-transcript-shared-secret
CALLS_TRANSCRIPT_AI_PROVIDER=managed_http
CALLS_TRANSCRIPT_AI_PROVIDER_HTTP_URL=http://localhost:3000/api/internal/calls/transcript-ai/provider
CALLS_TRANSCRIPT_AI_PROVIDER_HTTP_SECRET=replace-with-transcript-ai-http-secret

# Global AI provider selection
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini
AI_API_KEY=replace-with-global-ai-key
# For OpenAI-compatible providers, point this at their base API URL.
AI_BASE_URL=https://api.openai.com/v1

# Rate limits (requests per minute)
# Required in production for central rate limiting. Local development falls back to process memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_ADMIN=120
RATE_LIMIT_AGENT=600
RATE_LIMIT_AUTH_LOGIN=20
RATE_LIMIT_PORTAL_TICKET=40
RATE_LIMIT_TICKET_CREATE=60
RATE_LIMIT_TICKET_REPLY=120
RATE_LIMIT_DRAFT_SEND=120
RATE_LIMIT_EMAIL_SEND=120
RATE_LIMIT_WHATSAPP_SEND=120
RATE_LIMIT_WHATSAPP_RESEND=90
RATE_LIMIT_WHATSAPP_INBOUND=1200
RATE_LIMIT_CALLS_OUTBOUND=60

# Seed (local/admin setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-local-admin-password
ADMIN_NAME=Lead Admin
PRIMARY_PERSONAL_ADDRESS=admin@example.com

# R2 Storage
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-key
R2_SECRET_ACCESS_KEY=replace-with-r2-secret
R2_BUCKET=6esk-emails

# AI Knowledge Base ingestion safety
AI_KNOWLEDGE_REQUIRE_MALWARE_SCAN=true
AI_KNOWLEDGE_MALWARE_SCAN_URL=https://scanner.example.com/scan
AI_KNOWLEDGE_DOCUMENT_EXTRACTOR_URL=https://extractor.example.com/parse
AI_KNOWLEDGE_DOCUMENT_EXTRACTOR_TIMEOUT_MS=15000
AI_KNOWLEDGE_QUARANTINE_STORE_BLOBS=true
AI_KNOWLEDGE_QUARANTINE_REQUIRE_BLOBS=true
AI_KNOWLEDGE_QUARANTINE_PREFIX=ai-knowledge/quarantine
