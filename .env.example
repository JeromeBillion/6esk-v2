# Core
APP_URL=http://localhost:3000
NODE_ENV=development
DATABASE_URL=postgres://user:password@localhost:5432/6esk
SESSION_SECRET=replace-with-long-random-string
SESSION_COOKIE_NAME=sixesk_session
SESSION_TTL_DAYS=14

# Email (Resend)
RESEND_API_KEY=replace-with-resend-key
RESEND_WEBHOOK_SECRET=replace-with-resend-webhook-secret
RESEND_FROM_DOMAIN=6ex.co.za
SUPPORT_ADDRESS=support@6ex.co.za
# Shared machine-ingress secret for trusted external ticket creation.
INBOUND_SHARED_SECRET=replace-with-inbound-shared-secret
# Development/test escape hatch only. Production should use INBOUND_SHARED_SECRET.
INBOUND_ALLOW_UNAUTHENTICATED=false
AGENT_SECRET_KEY=replace-with-agent-secret-key
AGENT_OUTBOX_PROCESSING_RECOVERY_SECONDS=300
AGENT_OUTBOX_LANE_RETRY_SECONDS=10
AUTH_MFA_SECRET_ENCRYPTION_KEY=replace-with-64-character-hex-key
AUTH_REQUIRE_MFA_ADMIN=true
AUTH_MFA_ISSUER=6esk
AUTH_OAUTH_LOGIN_ENABLED=false
TENANT_INGRESS_SECRET_ENCRYPTION_KEY=replace-with-64-character-hex-key
TENANT_INGRESS_REQUIRE_SECRETS=true
PROVIDER_WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-64-character-hex-key
TENANT_PROVIDER_WEBHOOK_REQUIRE_SECRETS=false
TENANT_PROVIDER_WEBHOOK_SECRETS_JSON=
TENANT_PUBLIC_INGRESS_REQUIRE_ORIGIN=true
# Optional emergency origin-to-tenant map, for example:
# {"https://support.customer.example":{"tenantId":"tenant-uuid","workspaceKey":"primary"}}
TENANT_PUBLIC_INGRESS_ORIGINS_JSON=
TENANT_QUERY_GUARD_MODE=strict
ADMIN_IP_ALLOWLIST=127.0.0.1,::1
AGENT_IP_ALLOWLIST=
SECURITY_ALERT_WEBHOOK=
INBOUND_ALERT_WEBHOOK=
INBOUND_ALERT_THRESHOLD=5
INBOUND_ALERT_WINDOW_MINUTES=30
INBOUND_ALERT_COOLDOWN_MINUTES=60
INBOUND_RETRY_LIMIT=25
INBOUND_JOB_INTERVAL_SECONDS=0
INBOUND_JOB_MAX_RUNS=1
INBOUND_ALERT_EVERY_RUN=true
CRON_SECRET=replace-with-cron-secret
AGENT_MERGE_MIN_CONFIDENCE=0.85
TICKET_MERGE_MAX_MOVE_ROWS=5000
WHATSAPP_VERIFY_TOKEN=replace-with-whatsapp-verify-token
WHATSAPP_APP_SECRET=replace-with-whatsapp-app-secret
# Development/test escape hatch only. Production should use WHATSAPP_APP_SECRET.
WHATSAPP_ALLOW_UNSIGNED_WEBHOOKS=false
WHATSAPP_OUTBOX_SECRET=replace-with-whatsapp-outbox-secret
WHATSAPP_GRAPH_VERSION=v19.0
CALLS_PROVIDER=mock
CALLS_TWILIO_ACCOUNT_SID=
CALLS_TWILIO_AUTH_TOKEN=
CALLS_TWILIO_API_KEY_SID=
CALLS_TWILIO_API_KEY_SECRET=
# Optional for future browser-originated outbound calls. Incoming desk calls work without it.
CALLS_TWILIO_TWIML_APP_SID=
CALLS_TWILIO_FROM_NUMBER=
# Legacy migration fallback only. Normal v1 desk flow should ring browser clients inside 6esk.
CALLS_TWILIO_BRIDGE_TARGET=
CALLS_TWILIO_OPERATOR_RING_TIMEOUT_SECONDS=25
CALLS_TWILIO_CLIENT_TOKEN_TTL_SECONDS=3600
CALLS_OPERATOR_PRESENCE_TTL_SECONDS=90
CALLS_TWILIO_QUEUE_RETRY_LIMIT=6
# Optional comma-separated allowlist of caller IDs the app may request per call
CALLS_TWILIO_ALLOWED_CALLER_IDS=
CALLS_TWILIO_MEDIA_ALLOWED_HOSTS=api.twilio.com
CALLS_WEBHOOK_SECRET=replace-with-calls-webhook-secret
# Development/test escape hatch only. Production should use CALLS_WEBHOOK_SECRET or INBOUND_SHARED_SECRET.
CALLS_WEBHOOK_ALLOW_UNAUTHENTICATED=false
# Recommended secure signing string: "${timestamp}.${rawBody}".
CALLS_WEBHOOK_MAX_SKEW_SECONDS=300
# Temporary migration-only fallback. Keep false in production.
CALLS_WEBHOOK_ALLOW_LEGACY_BODY_SIGNATURE=false
CALLS_OUTBOX_SECRET=replace-with-calls-outbox-secret
CALLS_OUTBOX_PROCESSING_RECOVERY_SECONDS=300
CALL_RECORDING_FETCH_TIMEOUT_MS=10000
CALL_RECORDING_MAX_BYTES=52428800
CALLS_PROVIDER_FROM_PHONE=
CALLS_ENABLED=true
CALLS_REQUIRE_CONSENT=false
CALLS_CONSENT_TERMS_VERSION=
CALLS_ALLOWED_HOURS_TIMEZONE=UTC
CALLS_ALLOWED_HOURS_DAYS=
CALLS_ALLOWED_HOURS_START=
CALLS_ALLOWED_HOURS_END=
CALLS_MAX_CALLS_PER_HOUR=
CALLS_AI_MAX_CALLS_PER_HOUR=
CALLS_STT_PROVIDER=managed_http
CALLS_STT_PROVIDER_HTTP_URL=http://localhost:3000/api/internal/calls/stt/deepgram
CALLS_STT_PROVIDER_HTTP_SECRET=replace-with-stt-provider-secret
CALLS_STT_PROVIDER_HTTP_TIMEOUT_MS=15000
CALLS_STT_DEEPGRAM_API_KEY=replace-with-deepgram-key
CALLS_STT_DEEPGRAM_CALLBACK_TOKEN=replace-with-deepgram-callback-token
CALLS_STT_DEEPGRAM_MODEL=nova-3
CALLS_TRANSCRIPT_AI_PROVIDER=managed_http
CALLS_TRANSCRIPT_AI_PROVIDER_HTTP_URL=http://localhost:3000/api/internal/calls/transcript-ai/provider
CALLS_TRANSCRIPT_AI_PROVIDER_HTTP_SECRET=replace-with-transcript-ai-provider-secret
CALLS_TRANSCRIPT_AI_PROVIDER_HTTP_TIMEOUT_MS=60000
CALLS_TRANSCRIPT_SHARED_SECRET=replace-with-transcript-callback-secret
# Optional white-label external profile lookup plug.
EXTERNAL_PROFILE_SYSTEM=external-profile
EXTERNAL_PROFILE_LOOKUP_ENABLED=true
EXTERNAL_PROFILE_LOOKUP_URL=http://localhost:3000
EXTERNAL_PROFILE_LOOKUP_PATH=/api/v1/internal/support/users/lookup
EXTERNAL_PROFILE_LOOKUP_SECRET=replace-with-external-profile-lookup-secret
EXTERNAL_PROFILE_LOOKUP_TIMEOUT_MS=1500
EXTERNAL_PROFILE_LOOKUP_RETRY_COUNT=1

# Global AI provider selection
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini
AI_API_KEY=replace-with-global-ai-key
# For OpenAI-compatible providers, point this at their base API URL.
AI_BASE_URL=https://api.openai.com/v1
# Native Dexter runtime is still alpha-gated for production.
DEXTER_RUNTIME_ENABLED=false
# Required when enabling Dexter runtime in production.
DEXTER_RUNTIME_ALPHA_ACK=false
# `native` keeps Dexter in-process; `http_bridge` dispatches to an external runtime service.
DEXTER_RUNTIME_MODE=native
# Required when DEXTER_RUNTIME_MODE=http_bridge.
DEXTER_RUNTIME_HTTP_URL=
DEXTER_RUNTIME_HTTP_SECRET=
# Optional request timeout (milliseconds) for bridge health/event calls.
DEXTER_RUNTIME_HTTP_TIMEOUT_MS=7000

# AI Knowledge Base ingestion
# Optional dedicated worker secret. Falls back to CRON_SECRET when unset.
KNOWLEDGE_INGESTION_SECRET=
KNOWLEDGE_FILE_MAX_BYTES=26214400
KNOWLEDGE_INGESTION_RECOVERY_SECONDS=300
KNOWLEDGE_INGESTION_MAX_ATTEMPTS=5
KNOWLEDGE_EXTRACTED_TEXT_MAX_CHARS=1000000
KNOWLEDGE_CHUNK_TARGET_CHARS=1400
KNOWLEDGE_CHUNK_OVERLAP_CHARS=180
KNOWLEDGE_MAX_CHUNKS_PER_VERSION=500
AI_KNOWLEDGE_REQUIRE_MALWARE_SCAN=true
AI_KNOWLEDGE_MALWARE_SCAN_URL=https://scanner.example.com/scan
AI_KNOWLEDGE_MALWARE_SCAN_TIMEOUT_MS=5000
AI_KNOWLEDGE_DOCUMENT_EXTRACTOR_URL=https://extractor.example.com/parse
AI_KNOWLEDGE_DOCUMENT_EXTRACTOR_TIMEOUT_MS=15000
AI_KNOWLEDGE_QUARANTINE_STORE_BLOBS=false
AI_KNOWLEDGE_QUARANTINE_REQUIRE_BLOBS=false
AI_KNOWLEDGE_QUARANTINE_PREFIX=ai-knowledge/quarantine

# OAuth mailbox sync
OAUTH_ENCRYPTION_KEY=replace-with-64-character-hex-key
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/callback
GOOGLE_PUBSUB_TOPIC=
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/callback
MICROSOFT_WEBHOOK_URL=http://localhost:3000/api/oauth/webhooks/microsoft
MICROSOFT_AUTH_CLIENT_ID=
MICROSOFT_AUTH_CLIENT_SECRET=
MICROSOFT_AUTH_TENANT_ID=common
MICROSOFT_AUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/callback
ZOHO_OAUTH_CLIENT_ID=
ZOHO_OAUTH_CLIENT_SECRET=
ZOHO_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/callback

# Distributed rate limits. Required for production horizontally scaled deployments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate limits (requests per minute)
RATE_LIMIT_ADMIN=120
RATE_LIMIT_AGENT=600
RATE_LIMIT_AUTH_LOGIN=20
RATE_LIMIT_PORTAL_TICKET=40
RATE_LIMIT_TICKET_CREATE=60
RATE_LIMIT_TICKET_REPLY=120
RATE_LIMIT_DRAFT_SEND=120
RATE_LIMIT_EMAIL_SEND=120
RATE_LIMIT_WHATSAPP_SEND=120
RATE_LIMIT_WHATSAPP_RESEND=90
RATE_LIMIT_WHATSAPP_INBOUND=1200
RATE_LIMIT_CALLS_OUTBOUND=60

# Seed (local/admin setup)
ADMIN_EMAIL=jerome.choma@6ex.co.za
ADMIN_PASSWORD=replace-with-local-seed-password
ADMIN_NAME=Lead Admin
PRIMARY_PERSONAL_ADDRESS=jerome.choma@6ex.co.za

# R2 Storage
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-key
R2_SECRET_ACCESS_KEY=replace-with-r2-secret
R2_BUCKET=6esk-emails
